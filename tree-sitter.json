{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "lyr",
      "camelcase": "Lyr",
      "title": "Lyr",
      "scope": "source.lyr",
      "file-types": [
        "lyr"
      ],
      "injection-regex": "^lyr$",
      "class-name": "TreeSitterLyr"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "CTB Girls' Dorm standardized lyrics file format",
    "authors": [
      {
        "name": "btmxh",
        "email": "ngoduyanh.chip@gmail.com",
        "url": "https://github.com/btmxh"
      }
    ],
    "links": {
      "repository": "https://github.com/nrs-org/tree-sitter-lyr",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}