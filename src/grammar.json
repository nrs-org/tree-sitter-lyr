{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "lyr",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "SYMBOL",
        "name": "_line"
      }
    },
    "_line": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "tagged_line"
        },
        {
          "type": "SYMBOL",
          "name": "section_line"
        },
        {
          "type": "SYMBOL",
          "name": "blank_line"
        }
      ]
    },
    "tagged_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "tag",
          "content": {
            "type": "SYMBOL",
            "name": "tag"
          }
        },
        {
          "type": "STRING",
          "value": ":"
        },
        {
          "type": "FIELD",
          "name": "text",
          "content": {
            "type": "SYMBOL",
            "name": "text"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "section_line": {
      "type": "SEQ",
      "members": [
        {
          "type": "FIELD",
          "name": "section",
          "content": {
            "type": "SYMBOL",
            "name": "section"
          }
        },
        {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "\n"
            },
            {
              "type": "BLANK"
            }
          ]
        }
      ]
    },
    "tag": {
      "type": "CHOICE",
      "members": [
        {
          "type": "STRING",
          "value": "or"
        },
        {
          "type": "STRING",
          "value": "pa"
        }
      ]
    },
    "section": {
      "type": "PATTERN",
      "value": "\\[[^\\]\\n]+\\]"
    },
    "text": {
      "type": "PATTERN",
      "value": "[^\\n]*"
    },
    "blank_line": {
      "type": "PATTERN",
      "value": "\\n"
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "\\s"
    }
  ],
  "conflicts": [],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}